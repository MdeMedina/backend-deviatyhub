// ─────────────────────────────────────────
// CONFIGURACIÓN DE PRISMA
// ─────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), uuid_ossp(map: "uuid-ossp"), pgcrypto]
}

// ─────────────────────────────────────────
// ENUMS GLOBALES
// ─────────────────────────────────────────

enum ClinicPlan {
  STARTER
  PRO
}

enum IntegrationType {
  WHATSAPP
  INSTAGRAM
  GOOGLE_CALENDAR
  DENTALINK
  DENTIDESK
  GMAIL
}

enum MessageRole {
  USER
  ASSISTANT
  HUMAN
  SYSTEM
}

enum ConversationStatus {
  OPEN
  HUMAN_TAKEOVER
  CLOSED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  RESCHEDULED
  CANCELLED
  COMPLETED
}

enum AppointmentSource {
  AGENT
  HUMAN
  EXTERNAL
}

enum MetricEventType {
  CONVERSATION_STARTED
  CONVERSATION_CLOSED
  APPOINTMENT_SCHEDULED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_CANCELLED
  HUMAN_TAKEOVER
  OUT_OF_HOURS
  INTENTION_DETECTED
}

// ─────────────────────────────────────────
// 1. MÓDULO DEVIATY MASTER
// ─────────────────────────────────────────

model Clinic {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String
  slug         String   @unique
  plan         ClinicPlan @default(STARTER)
  active       Boolean?  @default(true)
  billingEmail String   @map("billing_email")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relaciones
  roles               Role[]
  users               User[]
  integrations        ClinicIntegration[]
  agentConfig         AgentConfig?
  auditLogs           AuditLog[]
  platformMetrics     PlatformMetric[]
  configs             ClinicConfig?
  schedules           ClinicSchedule[]
  unavailabilityBlocks UnavailabilityBlock[]
  policies            Policy[]
  doctors             Doctor[]
  treatments          Treatment[]
  offers              TreatmentOffer[]
  appointments        Appointment[]
  contacts            ClinicContact[]
  conversations       Conversation[]
  messages            Message[]
  patientSessions     PatientSession[]
  metricsEvents       MetricsEvent[]
  knowledgeOverrides  ClinicKnowledgeOverride[]

  @@map("clinics")
}

model Role {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId     String   @map("clinic_id") @db.Uuid
  name         String
  isSuperadmin Boolean?  @default(false) @map("is_superadmin")
  permissions  Json     @default("{}")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz

  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  users        User[]

  @@map("roles")
}

model User {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId      String   @map("clinic_id") @db.Uuid
  email         String   @unique
  passwordHash  String?  @map("password_hash")
  inviteToken   String?  @map("invite_token")
  inviteExpires DateTime? @map("invite_expires") @db.Timestamptz
  roleId        String   @map("role_id") @db.Uuid
  active        Boolean?  @default(true)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  clinic        Clinic   @relation(fields: [clinicId], references: [id])
  role          Role     @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  conversations Conversation[] @relation("AssignedOperator")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz

  user      User     @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model ClinicIntegration {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId     String   @map("clinic_id") @db.Uuid
  type         IntegrationType
  connected    Boolean?  @default(false)
  credentials  Json?
  lastTestedAt DateTime? @map("last_tested_at") @db.Timestamptz
  lastTestOk   Boolean?  @map("last_test_ok")
  updatedAt    DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  clinic       Clinic   @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, type])
  @@map("clinic_integrations")
}

model AgentConfig {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId  String   @unique @map("clinic_id") @db.Uuid
  actions   Json     @default("{}")
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  clinic    Clinic   @relation(fields: [clinicId], references: [id])

  @@map("agent_configs")
}

model AuditLog {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId  String   @map("clinic_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String
  entity    String
  entityId  String   @map("entity_id") @db.Uuid
  changes   Json     @default("{}")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz

  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model PlatformMetric {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId   String   @map("clinic_id") @db.Uuid
  metricType String   @map("metric_type")
  value      Float
  recordedAt DateTime? @default(now()) @map("recorded_at") @db.Timestamptz

  clinic     Clinic   @relation(fields: [clinicId], references: [id])

  @@map("platform_metrics")
}

// ─────────────────────────────────────────
// 2. MÓDULO CONFIGURACIÓN CLÍNICA
// ─────────────────────────────────────────

model ClinicConfig {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId  String   @unique @map("clinic_id") @db.Uuid
  name      String
  address   String
  phone     String
  email     String
  timezone  String
  language  String   @default("es")
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  clinic    Clinic   @relation(fields: [clinicId], references: [id])

  @@map("clinic_configs")
}

model ClinicSchedule {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId   String   @map("clinic_id") @db.Uuid
  dayOfWeek  Int      @map("day_of_week")
  openTime   String   @map("open_time")
  closeTime  String   @map("close_time")
  isOpen     Boolean?  @default(true) @map("is_open")

  clinic     Clinic   @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, dayOfWeek])
  @@map("clinic_schedules")
}

model UnavailabilityBlock {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId    String   @map("clinic_id") @db.Uuid
  name        String
  daysOfWeek  Int[]    @map("days_of_week")
  startTime   String   @map("start_time")
  endTime     String   @map("end_time")
  active      Boolean?  @default(true)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  clinic      Clinic   @relation(fields: [clinicId], references: [id])

  @@map("unavailability_blocks")
}

model Policy {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId    String   @map("clinic_id") @db.Uuid
  title       String
  description String
  active      Boolean?  @default(true)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  clinic      Clinic   @relation(fields: [clinicId], references: [id])

  @@map("policies")
}

model Doctor {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId  String   @map("clinic_id") @db.Uuid
  name      String
  title     String
  active    Boolean?  @default(true)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  treatments   DoctorTreatment[]
  appointments Appointment[]

  @@map("doctors")
}

model Treatment {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId        String   @map("clinic_id") @db.Uuid
  name            String
  category        String
  durationAvgMin  Int?     @map("duration_avg_min")
  encyclopediaRef String?  @map("encyclopedia_ref") @db.Uuid
  active          Boolean?  @default(true)
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  doctors      DoctorTreatment[]
  offers       TreatmentOffer[]
  appointments Appointment[]

  @@map("treatments")
}

model DoctorTreatment {
  id          String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId    String @map("clinic_id") @db.Uuid
  doctorId    String @map("doctor_id") @db.Uuid
  treatmentId String @map("treatment_id") @db.Uuid

  doctor      Doctor    @relation(fields: [doctorId], references: [id])
  treatment   Treatment @relation(fields: [treatmentId], references: [id])

  @@unique([doctorId, treatmentId])
  @@map("doctor_treatments")
}

model TreatmentOffer {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId    String   @map("clinic_id") @db.Uuid
  treatmentId String   @map("treatment_id") @db.Uuid
  label       String
  price       Int
  active      Boolean?  @default(true)
  validUntil  DateTime? @map("valid_until") @db.Timestamptz
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz

  clinic      Clinic    @relation(fields: [clinicId], references: [id])
  treatment   Treatment @relation(fields: [treatmentId], references: [id])

  @@map("treatment_offers")
}

model Appointment {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId        String   @map("clinic_id") @db.Uuid
  contactId       String?  @map("contact_id") @db.Uuid
  treatmentId     String?  @map("treatment_id") @db.Uuid
  doctorId        String?  @map("doctor_id") @db.Uuid
  conversationId  String?  @map("conversation_id") @db.Uuid
  contactName     String?  @map("contact_name")
  scheduledAt     DateTime @map("scheduled_at") @db.Timestamptz
  durationMin     Int      @map("duration_min")
  status          AppointmentStatus @default(PENDING)
  source          AppointmentSource @default(AGENT)
  externalId      String?  @map("external_id")
  notes           String?
  reminder3dSent  Boolean? @default(false) @map("reminder_3d_sent")
  reminder1dSent  Boolean? @default(false) @map("reminder_1d_sent")
  reminder1hSent  Boolean? @default(false) @map("reminder_1h_sent")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  contact      ClinicContact? @relation(fields: [contactId], references: [id])
  treatment    Treatment?    @relation(fields: [treatmentId], references: [id])
  doctor       Doctor?       @relation(fields: [doctorId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  history      AppointmentHistory[]

  @@map("appointments")
}

model AppointmentHistory {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  appointmentId String   @map("appointment_id") @db.Uuid
  event         String
  payload       Json?    @default("{}")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz

  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  @@map("appointment_history")
}

// ─────────────────────────────────────────
// 3. MÓDULO OPERATIVO
// ─────────────────────────────────────────

model ClinicContact {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId          String   @map("clinic_id") @db.Uuid
  phone             String?
  instagramUser     String?  @map("instagram_user")
  name              String?
  lastInteractionAt DateTime? @map("last_interaction_at") @db.Timestamptz
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  clinic        Clinic         @relation(fields: [clinicId], references: [id])
  conversations Conversation[]
  appointments  Appointment[]

  @@map("clinic_contacts")
}

model Conversation {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId       String   @map("clinic_id") @db.Uuid
  contactId      String?  @map("contact_id") @db.Uuid
  channel        String
  status         ConversationStatus @default(OPEN)
  currentStep    String   @default("inicio") @map("current_step")
  assignedUserId String?  @map("assigned_user_id") @db.Uuid
  startedAt      DateTime? @default(now()) @map("started_at") @db.Timestamptz
  closedAt       DateTime? @map("closed_at") @db.Timestamptz

  clinic      Clinic         @relation(fields: [clinicId], references: [id])
  contact     ClinicContact? @relation(fields: [contactId], references: [id])
  assignedTo  User?          @relation("AssignedOperator", fields: [assignedUserId], references: [id])
  messages    Message[]
  appointments Appointment[]
  patientSessions PatientSession[]
  metricsEvents   MetricsEvent[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  clinicId       String   @map("clinic_id") @db.Uuid
  role           MessageRole
  content        String
  langchainMeta  Json?    @default("{}") @map("langchain_meta")
  sentAt         DateTime? @default(now()) @map("sent_at") @db.Timestamptz

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  clinic         Clinic       @relation(fields: [clinicId], references: [id])

  @@map("messages")
}

model PatientSession {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId       String   @map("clinic_id") @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  rut            String
  expiresAt      DateTime @map("expires_at") @db.Timestamptz

  clinic       Clinic       @relation(fields: [clinicId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@map("patient_sessions")
}

model MetricsEvent {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId       String   @map("clinic_id") @db.Uuid
  eventType      MetricEventType @map("event_type")
  conversationId String?  @map("conversation_id") @db.Uuid
  value          Json?    @default("{}")
  certainty      Float?
  intention      String?
  hourOfDay      Int?     @map("hour_of_day")
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz

  clinic       Clinic       @relation(fields: [clinicId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])

  @@map("metrics_events")
}

// ─────────────────────────────────────────
// 4. MÓDULO RAG
// ─────────────────────────────────────────

model DentalEntry {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name             String
  category         String
  description      String
  procedure        String
  durationAvgMin   Int?     @map("duration_avg_min")
  indications      String[]
  contraindications String[]
  postCare         String[] @map("post_care")
  keywords         String[]
  embedding        Unsupported("vector(1536)")
  updatedAt        DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("dental_entries")
}

model ClinicKnowledgeOverride {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clinicId         String   @map("clinic_id") @db.Uuid
  dentalEntryRef   String?  @map("dental_entry_ref") @db.Uuid
  name             String
  category         String
  customProcedure  String?  @map("custom_procedure")
  customPostCare   String[] @map("custom_post_care")
  customIndications String[] @map("custom_indications")
  customNotes      String?  @map("custom_notes")
  active           Boolean?  @default(true)
  embedding        Unsupported("vector(1536)")
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  clinic           Clinic   @relation(fields: [clinicId], references: [id])

  @@map("clinic_knowledge_overrides")
}
